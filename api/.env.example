NODE_ENV=development

PORT=3000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nexus

JWT_SECRET=nexus-secret-key-change-in-production
JWT_EXPIRATION=7d

MP_PUBLIC_KEY=your-mercadopago-public-key
MP_ACCESS_TOKEN=your-mercadopago-access-token
FRONTEND_URL=http://localhost:8081

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backup & Recovery ─────────────────────────────────
# Backup destination on local disk
BACKUP_DIR=./backups
# Keep backups for N days (0 = forever)
BACKUP_RETENTION_DAYS=30

# S3-compatible object storage (leave empty to skip cloud backup)
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
